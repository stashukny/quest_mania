{
  "name": "quest-mania",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "start": "node dist/server/index.js",
    "compile": "tsc",
    "copy-assets": "copyfiles -u 1 \"server/db/*.sql\" dist/server/db && copyfiles -u 1 \"src/build/**/*\" dist/public",
    "build": "npm run compile && npm run copy-assets",
    "heroku-postbuild": "cd src && npm install && npm run build && cd .. && npm run build"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@types/body-parser": "^1.19.2",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "express": "^4.17.1",
    "typescript": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "copyfiles": "^2.4.1"
  },
  "main": "eslint.config.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "cacheDirectories": [
    "node_modules",
    "src/node_modules"
  ]
}
