{
  "compilerOptions": {
    "target": "ES2020",
    "module": "es2020",
    "outDir": "../dist/server",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true
  },
  "include": ["./**/*"],
  "ts-node": {
    "esm": true
  }
} 